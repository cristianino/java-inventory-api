# ===============================
# JAVA INVENTORY API - ENVIRONMENT VARIABLES
# ===============================
# Copia este archivo a .env y ajusta los valores según tu entorno local

# ===============================
# DATABASE CONFIGURATION
# ===============================
SPRING_DATASOURCE_URL=jdbc:postgresql://java-product-api-postgres-dev:5432/inventoryapi
SPRING_DATASOURCE_USERNAME=dev
SPRING_DATASOURCE_PASSWORD=devpass123

# ===============================
# EXTERNAL SERVICES
# ===============================
# URL base del servicio de productos
EXTERNAL_PRODUCTS_SERVICE_BASE_URL=http://java-product-api-app-dev:8080

# API Key para comunicarse con el servicio de productos
PRODUCTS_API_KEY=your-secret-api-key-here

# ===============================
# APPLICATION SECURITY
# ===============================
# API Key para autenticar las requests a este servicio
APP_API_KEY=your-secret-api-key-here

# ===============================
# SPRING PROFILES
# ===============================
# Perfil activo de Spring (docker, dev, prod, etc.)
SPRING_PROFILES_ACTIVE=docker

# ===============================
# DATABASE SEEDING
# ===============================
# Controla si se ejecuta el seeding automático (true/false)
DATABASE_SEEDING_ENABLED=true

# ===============================
# JAVA/JVM OPTIONS (for development)
# ===============================
# Opciones JVM para debug y desarrollo
JAVA_OPTS=-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5005